{
  "version": "0.1",
  "targets": [
    {
      "id": "openai",
      "hosts": ["api.openai.com"],
      "methods": ["POST"],
      "paths": [
        "/v1/chat/completions",
        "/v1/responses",
        "/v1/completions",
        "/v1/embeddings",
        "/v1/images/generations"
      ]
    },
    {
      "id": "anthropic",
      "hosts": ["api.anthropic.com"],
      "methods": ["POST"],
      "paths": ["/v1/messages", "/v1/complete"]
    },
    {
      "id": "gemini",
      "hosts": ["generativelanguage.googleapis.com"],
      "methods": ["POST"],
      "paths": [
        "/v1beta/models/*:generateContent",
        "/v1beta/models/*:streamGenerateContent",
        "/v1/models/*:generateContent",
        "/v1/models/*:streamGenerateContent"
      ]
    },
    {
      "id": "ollama",
      "hosts": ["127.0.0.1", "localhost"],
      "methods": ["POST"],
      "paths": ["/api/chat", "/api/generate"]
    },
    {
      "id": "mistral",
      "hosts": ["api.mistral.ai"],
      "methods": ["POST"],
      "paths": [
        "/v1/chat/completions",
        "/v1/fim/completions",
        "/v1/agents/completions"
      ]
    }
  ],
  "sensitive_names": [
    "authorization",
    "proxy-authorization",
    "cookie",
    "set-cookie",
    "api-key",
    "x-api-key",
    "x-goog-api-key",
    "anthropic-api-key",
    "openai-api-key",
    "google-api-key",
    "client-secret",
    "access-token",
    "refresh-token",
    "id-token",
    "session-token",
    "x-auth-token",
    "x-access-token",
    "password",
    "private-key",
    "credential",
    "credentials",
    "secret",
    "token"
  ]
}
