{
  "version": "0.1",
  "sensitive_names": [
    "authorization",
    "proxy-authorization",
    "cookie",
    "set-cookie",
    "api-key",
    "api-token",
    "x-api-key",
    "x-api-token",
    "x-goog-api-key",
    "anthropic-api-key",
    "openai-api-key",
    "google-api-key",
    "mistral-api-key",
    "groq-api-key",
    "xai-api-key",
    "huggingface-token",
    "subscription-key",
    "ocp-apim-subscription-key",
    "client-secret",
    "access-token",
    "refresh-token",
    "id-token",
    "session-token",
    "security-token",
    "x-auth-token",
    "x-access-token",
    "aws-access-key-id",
    "aws-secret-access-key",
    "password",
    "passphrase",
    "private-key",
    "secret-key",
    "credential",
    "credentials",
    "secret",
    "token"
  ],
  "text_patterns": [
    {
      "category": "private_key",
      "expression": "-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----[\\s\\S]*?-----END [A-Z0-9 ]*PRIVATE KEY-----",
      "matches": ["-----BEGIN PRIVATE KEY-----\nsynthetic-material\n-----END PRIVATE KEY-----"],
      "non_matches": ["-----BEGIN PUBLIC KEY-----\npublic-material\n-----END PUBLIC KEY-----"]
    },
    {
      "category": "anthropic_api_key",
      "expression": "\\bsk-ant-[A-Za-z0-9_-]{16,}\\b",
      "matches": ["sk-ant-abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["sk-ant-short"]
    },
    {
      "category": "openai_api_key",
      "expression": "\\bsk-(?:proj-|svcacct-)?[A-Za-z0-9_-]{16,}\\b",
      "matches": ["sk-proj-abcdefghijklmnopqrstuvwxyz123456", "sk-svcacct-abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["sk-short", "pk_test_abcdefghijklmnopqrstuvwxyz"]
    },
    {
      "category": "google_api_key",
      "expression": "\\bAIza[0-9A-Za-z_-]{20,}\\b",
      "matches": ["AIzaabcdefghijklmnopqrstuvwxyz123456789"],
      "non_matches": ["AIza-short"]
    },
    {
      "category": "bearer_token",
      "expression": "(?i)\\bBearer\\s+[A-Za-z0-9._~+/=-]{12,}",
      "matches": ["Bearer abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["Bearer short"]
    },
    {
      "category": "basic_auth",
      "expression": "(?i)\\bBasic\\s+[A-Za-z0-9+/]{12,}={0,2}",
      "matches": ["Basic QWxhZGRpbjpvcGVuIHNlc2FtZQ=="],
      "non_matches": ["Basic short"]
    },
    {
      "category": "jwt",
      "expression": "\\beyJ[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b",
      "matches": ["eyJabcdefghijk.abcdefghijk.abcdefghijk"],
      "non_matches": ["eyJshort.short.short"]
    },
    {
      "category": "aws_access_key",
      "expression": "\\b(?:AKIA|ASIA)[A-Z0-9]{16}\\b",
      "matches": ["AKIAABCDEFGHIJKLMNOP", "ASIA1234567890ABCDEF"],
      "non_matches": ["AKIA1234", "AKIAabcdefghijklmnop"]
    },
    {
      "category": "github_token",
      "expression": "\\b(?:gh[pousr]_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,})\\b",
      "matches": ["ghp_abcdefghijklmnopqrstuvwxyz123456", "github_pat_abcdefghijklmnopqrstuvwxyz_123456"],
      "non_matches": ["ghp_short", "github_pat_short"]
    },
    {
      "category": "gitlab_token",
      "expression": "\\bglpat-[A-Za-z0-9_-]{20,}\\b",
      "matches": ["glpat-abcdefghijklmnopqrstuvwxyz1234"],
      "non_matches": ["glpat-short"]
    },
    {
      "category": "huggingface_token",
      "expression": "\\bhf_[A-Za-z0-9]{20,}\\b",
      "matches": ["hf_abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["hf_short"]
    },
    {
      "category": "groq_api_key",
      "expression": "\\bgsk_[A-Za-z0-9]{20,}\\b",
      "matches": ["gsk_abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["gsk_short"]
    },
    {
      "category": "xai_api_key",
      "expression": "\\bxai-[A-Za-z0-9_-]{20,}\\b",
      "matches": ["xai-abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["xai-short"]
    },
    {
      "category": "slack_token",
      "expression": "\\bxox[baprs]-[A-Za-z0-9-]{20,}\\b",
      "matches": ["xo\u0078b-123456789012-abcdefghijklmnopqrstuvwxyz"],
      "non_matches": ["xoxb-short"]
    },
    {
      "category": "npm_token",
      "expression": "\\bnpm_[A-Za-z0-9]{20,}\\b",
      "matches": ["npm_abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["npm_short"]
    },
    {
      "category": "stripe_secret_key",
      "expression": "\\bsk_live_[A-Za-z0-9]{16,}\\b",
      "matches": ["sk\u005flive_abcdefghijklmnopqrstuvwxyz123456"],
      "non_matches": ["pk_live_abcdefghijklmnopqrstuvwxyz123456", "sk_live_short"]
    },
    {
      "category": "databricks_token",
      "expression": "\\bdapi[a-f0-9]{32}\\b",
      "matches": ["da\u0070i0123456789abcdef0123456789abcdef"],
      "non_matches": ["da\u0070i0123456789abcdef", "da\u0070i0123456789ABCDEF0123456789ABCDEF"]
    }
  ]
}
