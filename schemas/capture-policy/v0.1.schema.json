{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapturePolicy",
  "type": "object",
  "properties": {
    "sensitive_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CaptureTarget"
      }
    },
    "version": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "version",
    "targets",
    "sensitive_names"
  ],
  "$defs": {
    "CaptureTarget": {
      "type": "object",
      "properties": {
        "hosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "hosts",
        "methods",
        "paths"
      ]
    }
  }
}
