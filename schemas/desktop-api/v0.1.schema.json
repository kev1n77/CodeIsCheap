{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkspaceBootstrap",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "capture": {
      "$ref": "#/$defs/CaptureState"
    },
    "compatibility": {
      "$ref": "#/$defs/CaptureCompatibility"
    },
    "requests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CapturedRequest"
      }
    },
    "source": {
      "$ref": "#/$defs/WorkspaceSource"
    }
  },
  "required": [
    "apiVersion",
    "source",
    "capture",
    "compatibility",
    "requests"
  ],
  "$defs": {
    "AnatomyItem": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "content",
        "source"
      ]
    },
    "AnatomySection": {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "evidence": {
          "$ref": "#/$defs/EvidenceLevel"
        },
        "id": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AnatomyItem"
          }
        },
        "title": {
          "type": "string"
        },
        "tokenCount": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "title",
        "count",
        "evidence",
        "items"
      ]
    },
    "ApplicationAttributionSource": {
      "type": "string",
      "enum": [
        "client_label",
        "user_agent",
        "capture_mode"
      ]
    },
    "ApplicationConfidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "CaptureCompatibility": {
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/CompatibilityAction"
        },
        "code": {
          "$ref": "#/$defs/CaptureCompatibilityCode"
        },
        "confidence": {
          "$ref": "#/$defs/CompatibilityConfidence"
        },
        "recommendedMode": {
          "$ref": "#/$defs/CaptureMode"
        },
        "status": {
          "$ref": "#/$defs/CaptureCompatibilityStatus"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CompatibilityStep"
          }
        },
        "summary": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "status",
        "confidence",
        "title",
        "summary",
        "recommendedMode",
        "action",
        "steps"
      ]
    },
    "CaptureCompatibilityCode": {
      "type": "string",
      "enum": [
        "gateway_ready",
        "gateway_unavailable",
        "proxy_bundle_unavailable",
        "proxy_unavailable",
        "certificate_missing",
        "certificate_invalid",
        "certificate_trust_required",
        "capture_paused",
        "proxy_capture_unobserved",
        "proxy_capture_observed"
      ]
    },
    "CaptureCompatibilityStatus": {
      "type": "string",
      "enum": [
        "ready",
        "attention",
        "blocked"
      ]
    },
    "CaptureMode": {
      "type": "string",
      "enum": [
        "gateway",
        "proxy"
      ]
    },
    "CaptureState": {
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean"
        },
        "canControl": {
          "type": "boolean"
        },
        "certificateAuthority": {
          "$ref": "#/$defs/CertificateAuthority"
        },
        "endpoint": {
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/CaptureMode"
        },
        "profile": {
          "type": "string"
        },
        "proxyAvailable": {
          "type": "boolean"
        },
        "requestCount": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "storage": {
          "type": "string"
        }
      },
      "required": [
        "active",
        "canControl",
        "proxyAvailable",
        "mode",
        "profile",
        "endpoint",
        "storage",
        "requestCount",
        "certificateAuthority"
      ]
    },
    "CaptureStatus": {
      "type": "string",
      "enum": [
        "complete",
        "streaming",
        "error"
      ]
    },
    "CapturedRequest": {
      "type": "object",
      "properties": {
        "application": {
          "type": "string"
        },
        "applicationConfidence": {
          "$ref": "#/$defs/ApplicationConfidence"
        },
        "applicationProcessId": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "applicationSource": {
          "$ref": "#/$defs/ApplicationAttributionSource"
        },
        "costSource": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "costUsd": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "detail": {
          "$ref": "#/$defs/RequestDetail"
        },
        "durationMs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "hasTools": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "observedAtUnixMs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "operation": {
          "type": "string"
        },
        "pricingVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "promptPreview": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "semanticFingerprint": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/CaptureStatus"
        },
        "tokenSource": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "observedAtUnixMs",
        "application",
        "applicationSource",
        "applicationConfidence",
        "provider",
        "operation",
        "model",
        "status",
        "hasTools",
        "promptPreview",
        "detail"
      ]
    },
    "CertificateAuthority": {
      "type": "object",
      "properties": {
        "canManageTrust": {
          "type": "boolean"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "fingerprintSha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "privateMaterial": {
          "$ref": "#/$defs/CertificatePrivateMaterial"
        },
        "state": {
          "$ref": "#/$defs/CertificateAuthorityState"
        },
        "subject": {
          "type": [
            "string",
            "null"
          ]
        },
        "trust": {
          "$ref": "#/$defs/CertificateTrust"
        },
        "validFromUnixMs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "validUntilUnixMs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        }
      },
      "required": [
        "state",
        "canManageTrust",
        "privateMaterial",
        "trust"
      ]
    },
    "CertificateAuthorityState": {
      "type": "string",
      "enum": [
        "missing",
        "ready",
        "invalid"
      ]
    },
    "CertificatePrivateMaterial": {
      "type": "string",
      "enum": [
        "missing",
        "restricted",
        "unchecked",
        "insecure"
      ]
    },
    "CertificateTrust": {
      "type": "string",
      "enum": [
        "unchecked",
        "trusted",
        "not_trusted",
        "unsupported"
      ]
    },
    "CompatibilityAction": {
      "type": "string",
      "enum": [
        "none",
        "resume_capture",
        "trust_certificate",
        "use_gateway"
      ]
    },
    "CompatibilityConfidence": {
      "type": "string",
      "enum": [
        "high",
        "low"
      ]
    },
    "CompatibilityStep": {
      "type": "object",
      "properties": {
        "detail": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/CompatibilityStepStatus"
        }
      },
      "required": [
        "id",
        "status",
        "label",
        "detail"
      ]
    },
    "CompatibilityStepStatus": {
      "type": "string",
      "enum": [
        "pass",
        "attention",
        "blocked",
        "pending"
      ]
    },
    "EvidenceLevel": {
      "type": "string",
      "enum": [
        "observed",
        "derived",
        "inferred",
        "unknown"
      ]
    },
    "EvidenceLocator": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "json_pointer"
            },
            "pointer": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "pointer"
          ]
        },
        {
          "type": "object",
          "properties": {
            "end": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "kind": {
              "type": "string",
              "const": "text_range"
            },
            "pointer": {
              "type": "string"
            },
            "start": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "pointer",
            "start",
            "end"
          ]
        }
      ]
    },
    "MetricSource": {
      "type": "string",
      "enum": [
        "reported",
        "estimated"
      ]
    },
    "RequestDetail": {
      "type": "object",
      "properties": {
        "anatomy": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AnatomySection"
          }
        },
        "raw": true,
        "timeline": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TimelineEvent"
          }
        }
      },
      "required": [
        "anatomy",
        "timeline",
        "raw"
      ]
    },
    "TimelineEvent": {
      "type": "object",
      "properties": {
        "detail": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "locator": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceLocator"
            },
            {
              "type": "null"
            }
          ]
        },
        "offsetMs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "sequence": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind",
        "title",
        "detail"
      ]
    },
    "WorkspaceSource": {
      "type": "string",
      "enum": [
        "encrypted_local",
        "synthetic_fixture"
      ]
    }
  }
}
